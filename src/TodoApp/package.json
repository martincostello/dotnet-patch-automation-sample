{
  "name": "todoapp",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "An ASP.NET Core app for managing Todo items",
  "scripts": {
    "build": "npm run compile && npm run format && npm run lint && npm test",
    "compile": "webpack",
    "format": "prettier --write scripts/**/*.ts && stylelint --fix lax styles/**/*.css",
    "lint": "eslint scripts",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/martincostello/dotnet-patch-automation-sample.git"
  },
  "author": "martincostello",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/eslint-plugin": "1.6.15",
    "css-loader": "7.1.4",
    "css-minimizer-webpack-plugin": "8.0.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "mini-css-extract-plugin": "2.10.2",
    "moment": "2.30.1",
    "prettier": "3.8.3",
    "stylelint-config-standard": "^40.0.0",
    "ts-loader": "9.5.7",
    "tsify": "5.0.4",
    "typescript": "6.0.3",
    "vitest": "4.1.4",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2",
    "webpack-remove-empty-scripts": "1.1.1"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "endOfLine": "auto",
    "printWidth": 80,
    "quoteProps": "consistent",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "es5",
    "useTabs": false
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard"
    ]
  }
}
